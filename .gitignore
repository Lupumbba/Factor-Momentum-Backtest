# Virtual environment (never commit)
.venv/

# Python cache files
__pycache__/
*.pyc

# macOS junk
.DS_Store

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Local data cache (downloaded prices etc.)
Data/

# Ignore everything in Results
Results/*
# …except the assets folder
!Results/assets/
!Results/assets/**
# …and the generated local website
!Results/site/
!Results/site/**
# …and lightweight generated result summaries
!Results/latest_selection.csv
!Results/cost_grid_metrics.csv
!Results/universe_comparison.csv
!Results/universes/
Results/universes/**
!Results/universes/*/
!Results/universes/*/latest_selection.csv
!Results/universes/*/cost_grid_metrics.csv
!Results/strategies/
Results/strategies/**
!Results/strategies/*/
!Results/strategies/*/*.csv
